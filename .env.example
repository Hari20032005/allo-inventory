# Neon / Supabase / any managed Postgres connection string
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Upstash Redis REST — from https://console.upstash.com
UPSTASH_REDIS_REST_URL="https://your-instance.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-token"

# Random secret used to authenticate the Vercel Cron job
CRON_SECRET="change-me-to-a-long-random-string"
